# Порт на хосте для веб-интерфейса
HOST_PORT_WEB=7002

# Параметры запроса NDVI по умолчанию
VITE_DEFAULT_WINDOW=5
VITE_DEFAULT_CLOUD=20

# Базовый слой карты: esri | osm
VITE_DEFAULT_BASEMAP=esri

# Каталог — динамическая подгрузка тайлов
VITE_CATALOG_DEBOUNCE_MS=100
VITE_CATALOG_MAX_TILES=200
VITE_CATALOG_REFRESH_MS=300000
